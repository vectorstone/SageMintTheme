<idea-plugin>
    <id>com.wangxiaoguang.sageminttheme</id>
    <name>Sage Mint Theme</name>

    <vendor url="https://github.com/vectorstone/SageMintTheme">vectorstone</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <themeProvider id="com.wangxiaoguang.sageminttheme" path="/themes/sage-mint.theme.json"/>
        <bundledColorScheme id="Sage Mint" path="/colorSchemes/SageMint"/>
        <themeProvider id="com.wangxiaoguang.sageminttheme.night" path="/themes/sage-mint-night.theme.json"/>
        <bundledColorScheme id="Sage Mint Night" path="/colorSchemes/SageMintNight"/>
    </extensions>
</idea-plugin>
